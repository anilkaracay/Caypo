{
  "name": "@caypo/mpp-canton",
  "version": "0.1.0",
  "description": "Canton Network payment method for the Machine Payments Protocol (MPP) — accept and make USDCx payments in any HTTP API",
  "keywords": ["canton", "mpp", "payments", "ai-agents", "stablecoin", "usdcx", "blockchain", "machine-payments", "stripe", "tempo"],
  "author": "Cayvox Labs <dev@caypo.xyz>",
  "homepage": "https://github.com/anilkaracay/Caypo/tree/main/packages/mpp",
  "repository": { "type": "git", "url": "https://github.com/anilkaracay/Caypo.git", "directory": "packages/mpp" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "mppx": "*"
  },
  "devDependencies": {
    "mppx": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "license": "(Apache-2.0 OR MIT)"
}
