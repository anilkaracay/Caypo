{
  "name": "@caypo/canton-sdk",
  "version": "0.1.0",
  "description": "Core SDK for AI agent banking on Canton Network — USDCx transfers, encrypted wallets, safeguards, and MPP auto-pay",
  "keywords": ["canton", "sdk", "payments", "ai-agents", "stablecoin", "usdcx", "blockchain", "machine-payments", "wallet", "defi"],
  "author": "Cayvox Labs <dev@caypo.xyz>",
  "homepage": "https://github.com/anilkaracay/Caypo/tree/main/packages/sdk",
  "repository": { "type": "git", "url": "https://github.com/anilkaracay/Caypo.git", "directory": "packages/sdk" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@caypo/mpp-canton": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "license": "(Apache-2.0 OR MIT)"
}
