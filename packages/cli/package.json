{
  "name": "@caypo/canton-cli",
  "version": "0.1.0",
  "description": "CLI for AI agent banking on Canton Network — send, receive, and pay for APIs with USDCx",
  "keywords": ["canton", "cli", "payments", "ai-agents", "usdcx", "blockchain", "machine-payments", "wallet", "mpp"],
  "author": "Cayvox Labs <dev@caypo.xyz>",
  "homepage": "https://github.com/anilkaracay/Caypo/tree/main/packages/cli",
  "repository": { "type": "git", "url": "https://github.com/anilkaracay/Caypo.git", "directory": "packages/cli" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "caypo": "./dist/index.js",
    "canton-agent": "./dist/index.js",
    "ca": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@caypo/canton-sdk": "workspace:*",
    "commander": "^13.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0",
    "inquirer": "^12.6.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "license": "(Apache-2.0 OR MIT)"
}
