{
  "name": "@caypo/canton-mcp",
  "version": "0.1.0",
  "description": "MCP server connecting Canton Network to Claude Desktop, Cursor, and Windsurf — 33 tools, 20 prompts",
  "keywords": ["canton", "mcp", "ai-agents", "claude", "cursor", "windsurf", "payments", "usdcx", "model-context-protocol"],
  "author": "Cayvox Labs <dev@caypo.xyz>",
  "homepage": "https://github.com/anilkaracay/Caypo/tree/main/packages/mcp",
  "repository": { "type": "git", "url": "https://github.com/anilkaracay/Caypo.git", "directory": "packages/mcp" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "caypo-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@caypo/canton-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "license": "(Apache-2.0 OR MIT)"
}
